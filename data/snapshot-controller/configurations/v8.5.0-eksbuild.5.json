{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "additionalProperties": false,
  "description": "Configurable parameters of the CSI Snapshot Controller EKS Addon",
  "properties": {
    "additionalArgs": {
      "default": [],
      "description": "Additional arguments passed to the CSI Snapshot Controller container",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "affinity": {
      "default": {
        "nodeAffinity": {
          "preferredDuringSchedulingIgnoredDuringExecution": [
            {
              "preference": {
                "matchExpressions": [
                  {
                    "key": "eks.amazonaws.com/compute-type",
                    "operator": "NotIn",
                    "values": [
                      "fargate",
                      "auto",
                      "hybrid"
                    ]
                  }
                ]
              },
              "weight": 1
            }
          ]
        },
        "podAntiAffinity": {
          "preferredDuringSchedulingIgnoredDuringExecution": [
            {
              "podAffinityTerm": {
                "labelSelector": {
                  "matchExpressions": [
                    {
                      "key": "app",
                      "operator": "In",
                      "values": [
                        "snapshot-controller"
                      ]
                    }
                  ]
                },
                "topologyKey": "kubernetes.io/hostname"
              },
              "weight": 100
            }
          ]
        }
      },
      "description": "Affinity of the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "logLevel": {
      "default": null,
      "description": "Log verbosity of the CSI Snapshot Controller container",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "nodeSelector": {
      "default": {
        "kubernetes.io/os": "linux"
      },
      "description": "Node selector of the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "podLabels": {
      "default": null,
      "description": "Additional labels for the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "priorityClassName": {
      "default": null,
      "description": "Priority class name for the CSI Snapshot Controller pod",
      "type": [
        "string",
        "null"
      ]
    },
    "resources": {
      "default": {
        "limits": {
          "memory": "256Mi"
        },
        "requests": {
          "cpu": "100m",
          "memory": "40Mi"
        }
      },
      "description": "Resource requests/limits of the CSI Snapshot Controller container",
      "type": [
        "object",
        "null"
      ]
    },
    "tolerations": {
      "default": [
        {
          "key": "CriticalAddonsOnly",
          "operator": "Exists"
        },
        {
          "effect": "NoExecute",
          "operator": "Exists",
          "tolerationSeconds": 300
        }
      ],
      "description": "Tolerations of the CSI Snapshot Controller pod",
      "items": {
        "type": "object"
      },
      "type": "array"
    }
  },
  "type": "object"
}
