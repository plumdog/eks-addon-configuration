{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "additionalProperties": false,
  "description": "Configurable parameters of the CSI Snapshot Controller EKS Addon",
  "properties": {
    "additionalArgs": {
      "default": [],
      "description": "Additional arguments passed to the CSI Snapshot Controller container",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "affinity": {
      "default": {
        "nodeAffinity": {
          "preferredDuringSchedulingIgnoredDuringExecution": [
            {
              "preference": {
                "matchExpressions": [
                  {
                    "key": "eks.amazonaws.com/compute-type",
                    "operator": "NotIn",
                    "values": [
                      "fargate",
                      "auto",
                      "hybrid"
                    ]
                  }
                ]
              },
              "weight": 1
            }
          ]
        },
        "podAntiAffinity": {
          "preferredDuringSchedulingIgnoredDuringExecution": [
            {
              "podAffinityTerm": {
                "labelSelector": {
                  "matchExpressions": [
                    {
                      "key": "app",
                      "operator": "In",
                      "values": [
                        "snapshot-controller"
                      ]
                    }
                  ]
                },
                "topologyKey": "kubernetes.io/hostname"
              },
              "weight": 100
            }
          ]
        }
      },
      "description": "Affinity of the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "logLevel": {
      "default": null,
      "description": "Log verbosity of the CSI Snapshot Controller container",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "nodeSelector": {
      "default": {
        "kubernetes.io/os": "linux"
      },
      "description": "Node selector of the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "podAnnotations": {
      "additionalProperties": {
        "type": "string"
      },
      "default": null,
      "description": "Additional annotations for the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "podDisruptionBudget": {
      "additionalProperties": false,
      "description": "Pod disruption budget configurations for the CSI Snapshot Controller pods",
      "not": {
        "required": [
          "maxUnavailable",
          "minAvailable"
        ]
      },
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enables the managed PodDisruptionBudget",
          "type": "boolean"
        },
        "maxUnavailable": {
          "anyOf": [
            {
              "pattern": "^[0-9]+%$",
              "type": "string"
            },
            {
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 1,
          "description": "Maximum number or percentage of unavailable pods during a voluntary disruption"
        },
        "minAvailable": {
          "anyOf": [
            {
              "pattern": "^[0-9]+%$",
              "type": "string"
            },
            {
              "minimum": 0,
              "type": "integer"
            }
          ],
          "description": "Minimum number or percentage of available pods during a voluntary disruption"
        }
      },
      "type": "object"
    },
    "podLabels": {
      "default": null,
      "description": "Additional labels for the CSI Snapshot Controller pod",
      "type": [
        "object",
        "null"
      ]
    },
    "priorityClassName": {
      "default": null,
      "description": "Priority class name for the CSI Snapshot Controller pod",
      "type": [
        "string",
        "null"
      ]
    },
    "resources": {
      "default": {
        "limits": {
          "memory": "256Mi"
        },
        "requests": {
          "cpu": "100m",
          "memory": "40Mi"
        }
      },
      "description": "Resource requests/limits of the CSI Snapshot Controller container",
      "type": [
        "object",
        "null"
      ]
    },
    "tolerations": {
      "default": [
        {
          "key": "CriticalAddonsOnly",
          "operator": "Exists"
        },
        {
          "effect": "NoExecute",
          "operator": "Exists",
          "tolerationSeconds": 300
        }
      ],
      "description": "Tolerations of the CSI Snapshot Controller pod",
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "topologySpreadConstraints": {
      "default": [],
      "description": "Topology spread constraints for the CSI Snapshot Controller pod",
      "items": {
        "type": "object"
      },
      "type": "array"
    }
  },
  "type": "object"
}
