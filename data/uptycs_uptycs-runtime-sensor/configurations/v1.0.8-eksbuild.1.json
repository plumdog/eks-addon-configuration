{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "daemonset": {
      "additionalProperties": false,
      "description": "Uptycs Runtime Sensor daemonset",
      "properties": {
        "containers": {
          "properties": {
            "resources": {
              "description": "Resources allocated to Uptycs Runtime Sensor daemonset",
              "type": "object"
            }
          },
          "type": "object"
        },
        "priorityClassName": {
          "description": "Optional Kubernetes PriorityClass for the Uptycs Runtime Sensor pods",
          "type": [
            "string",
            "null"
          ]
        },
        "tolerations": {
          "description": "Tolerations for Uptycs Runtime Sensor pods",
          "items": {
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "uptycsCloud": {
      "description": "Uptycs cloud service onto which the cluster is enrolled",
      "type": "string"
    }
  },
  "required": [
    "daemonset",
    "uptycsCloud"
  ],
  "title": "Values",
  "type": "object"
}
